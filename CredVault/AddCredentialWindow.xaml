<Window x:Class="CredVault.AddCredentialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add credential" Height="250" Width="360"
        WindowStartupLocation="CenterOwner" FontFamily="Segoe UI" FontSize="13"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Name (used as the env var name)" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" Padding="4"/>

        <TextBlock x:Name="SecretLabel" Text="Secret value" Margin="0,12,0,4"/>
        <PasswordBox x:Name="SecretBox" Padding="4"/>

        <TextBlock x:Name="ErrorText" Foreground="#A4262C" Margin="0,8,0,0"
                   TextWrapping="Wrap" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="90" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
