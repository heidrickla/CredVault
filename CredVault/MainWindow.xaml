<Window x:Class="CredVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CredVault" Height="640" Width="480"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Background>
        <!-- Scale-to-fill and crop; anchored to the top so the shield /
             keyhole stays in frame at the app's shorter aspect ratio. -->
        <ImageBrush ImageSource="Assets/background.png"
                    Stretch="UniformToFill" AlignmentY="Top"/>
    </Window.Background>

    <Grid>
        <!-- Dark scrim over the artwork so controls and text stay legible. -->
        <Rectangle Fill="#A6080B14"/>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="160"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Stored credentials"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

            <ListBox Grid.Row="1" x:Name="CredentialList" BorderThickness="1"
                      Background="#33101725" BorderBrush="{StaticResource BorderBrushSoft}"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.CanContentScroll="False"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#C2202630"
                                BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1"
                                CornerRadius="6" Margin="4,3" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;"
                                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Edit" Padding="8,3" FontSize="11" Margin="0,0,4,0"
                                            Click="EditCredential_Click" Tag="{Binding Name}"/>
                                    <Button Content="Remove" Padding="8,3" FontSize="11"
                                            Click="RemoveCredential_Click" Tag="{Binding Name}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2" Content="+ Add credential" Margin="0,8,0,0" Padding="6,6"
                    HorizontalAlignment="Stretch" Click="AddCredential_Click"/>

            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                <TextBlock Text="Launch protected session"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="CommandBox" FontFamily="Consolas" FontSize="12" Padding="6"
                         Background="#CC0C0F17" TextChanged="CommandBox_TextChanged"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="LaunchButton" Content="Launch" Width="100" Margin="0,0,8,0"
                            Style="{StaticResource AccentButton}" Click="Launch_Click"/>
                    <Button x:Name="CancelButton" Content="Cancel" Width="100" IsEnabled="False"
                            Click="Cancel_Click"/>
                </StackPanel>
                <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" Margin="0,8,0,0"
                           TextWrapping="Wrap" Visibility="Collapsed"/>
            </StackPanel>

            <TextBox Grid.Row="4" x:Name="LogBox" Margin="0,16,0,0" FontFamily="Consolas" FontSize="11"
                      Background="#CC0C0F17" Foreground="{StaticResource TextMutedBrush}"
                      IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                      AcceptsReturn="True"/>
        </Grid>
    </Grid>
</Window>
