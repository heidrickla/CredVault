<Window x:Class="CredVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CredVault" Height="640" Width="480"
        Background="#F3F2F1" FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Stored credentials" Foreground="#605E5C" Margin="0,0,0,8"/>

        <ListBox Grid.Row="1" x:Name="CredentialList" BorderThickness="1" BorderBrush="#E1DFDD"
                  Background="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;"
                                       Foreground="#A19F9D" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Edit" Padding="6,2" FontSize="11" Margin="0,0,4,0"
                                    Click="EditCredential_Click" Tag="{Binding Name}"/>
                            <Button Content="Remove" Padding="6,2" FontSize="11"
                                    Click="RemoveCredential_Click" Tag="{Binding Name}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="2" Content="+ Add credential" Margin="0,8,0,0" Padding="6,4"
                HorizontalAlignment="Stretch" Click="AddCredential_Click"/>

        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock Text="Launch protected session" Foreground="#605E5C" Margin="0,0,0,6"/>
            <TextBox x:Name="CommandBox" FontFamily="Consolas" FontSize="12" Padding="6"
                     TextChanged="CommandBox_TextChanged"/>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button x:Name="LaunchButton" Content="Launch" Width="100" Margin="0,0,8,0"
                        Click="Launch_Click"/>
                <Button x:Name="CancelButton" Content="Cancel" Width="100" IsEnabled="False"
                        Click="Cancel_Click"/>
            </StackPanel>
            <TextBlock x:Name="ErrorText" Foreground="#A4262C" Margin="0,8,0,0"
                       TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>

        <TextBox Grid.Row="4" x:Name="LogBox" Margin="0,16,0,0" FontFamily="Consolas" FontSize="11"
                  Background="#F9F8F7" BorderBrush="#E1DFDD" IsReadOnly="True"
                  TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
    </Grid>
</Window>
